{
  "name": "funeral-frontend",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "cd .. && ./sync-frontend-from-pom.sh && cd funeral-frontend && vite",
    "build": "cd .. && ./sync-frontend-from-pom.sh && cd funeral-frontend && rm -rf dist && vite build && cd .. && ./sync-dist-to-backend.sh",
    "preview": "vite preview",
    "sync-version": "cd .. && ./sync-frontend-from-pom.sh",
    "sync-to-backend": "cd .. && ./sync-dist-to-backend.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{js,vue}\""
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "crypto-js": "^4.2.0",
    "element-plus": "^2.14.2",
    "js-untar": "2.0.0",
    "pako": "^3.0.1",
    "pinia": "^3.0.4",
    "tar-js": "^0.3.0",
    "vue": "^3.5.39",
    "vue-json-pretty": "^2.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.4",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^5.0.10",
    "vitest": "^2.1.9",
    "vue-eslint-parser": "^10.4.1"
  }
}
